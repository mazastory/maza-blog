---
export const prerender = false;
if (Astro.url.pathname === '/debug-index') {
  return new Response(JSON.stringify({ path: Astro.url.pathname }), { status: 200 });
}
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import HeroModern from '../components/hero/HeroModern.astro';
import HeroClassic from '../components/hero/HeroClassic.astro';
import HeroMagazine from '../components/hero/HeroMagazine.astro';
import HeroMinimal from '../components/hero/HeroMinimal.astro';
import HeroSplit from '../components/hero/HeroSplit.astro';
import HeroApp from '../components/hero/HeroApp.astro';
import { getApprovedPosts, getRequestDomain, getSiteConfig } from '../lib/api';
import { useTranslation } from '../lib/i18n';

import { generateThemeVars } from '../lib/theme';

// 캐시 설정으로 로딩 속도 대폭 개선 (SWR 적용)
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=60, stale-while-revalidate=86400, stale-if-error=86400');
Astro.response.headers.set('Netlify-CDN-Cache-Control', 'public, max-age=0, s-maxage=60, stale-while-revalidate=86400, stale-if-error=86400');

// 서버사이드(런타임)에서 접속한 도메인 기준으로 승인된 포스트만 렌더링
const url = new URL(Astro.request.url);
const domain = getRequestDomain(Astro.request);
const bypassCache = url.searchParams.has('_bust');

const siteConfig = await getSiteConfig(domain, { bypassCache });
const theme = generateThemeVars(siteConfig);
const lang = Astro.locals.lang || siteConfig?.metadata?.campaign?.language?.[0] || 'ko';
const t = useTranslation(lang);

const posts = await getApprovedPosts(domain, lang);

let blogName = siteConfig?.blog_name || "Maza Blog";
let blogDescription = siteConfig?.niche || "Welcome to our blog.";
let heroSubtitle = siteConfig?.metadata?.hero_subtitle || t.welcome;

if (lang === 'en' && siteConfig?.metadata?.primary_topic_en) {
  blogDescription = siteConfig.metadata.primary_topic_en;
} else if (lang === 'ja' && siteConfig?.metadata?.primary_topic_ja) {
  blogDescription = siteConfig.metadata.primary_topic_ja;
}

if (lang === 'en' && siteConfig?.metadata?.hero_subtitle_en) {
  heroSubtitle = siteConfig.metadata.hero_subtitle_en;
} else if (lang === 'ja' && siteConfig?.metadata?.hero_subtitle_ja) {
  heroSubtitle = siteConfig.metadata.hero_subtitle_ja;
}

const featuredPost = posts.length > 0 ? posts[0] : null;
const recentPosts = posts.slice(1);

// Featured Post 대표 이미지 추출
let featuredImage = null;
if (featuredPost) {
  const metaImg = featuredPost.metadata?.data?.image1 
    || featuredPost.metadata?.blocks?.find((b: any) => b.type === 'image')?.url
    || featuredPost.metadata?.thumbnail_url
    || featuredPost.thumbnail_url
    || null;
  if (metaImg) featuredImage = metaImg;
}

const heroBgUrl = siteConfig?.metadata?.hero_bg_url || siteConfig?.metadata?.hero_image_url || null;
const heroTemplate = siteConfig?.metadata?.hero_template || 'modern';

const feedClass = theme.feedStyle === 'list' 
  ? 'flex flex-col gap-8 max-w-4xl mx-auto' 
  : (theme.feedStyle === 'masonry' ? 'columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6' : 'grid gap-6 md:gap-8 sm:grid-cols-2 lg:grid-cols-3');

---

<Layout preloadImage={featuredImage} siteConfig={siteConfig}>
  <div class="mx-auto max-w-7xl px-4 pt-8 pb-10 md:px-6 md:pt-20 md:pb-14">
    {heroTemplate === 'modern' && <HeroModern blogName={blogName} blogDescription={blogDescription} heroBgUrl={heroBgUrl} t={t} posts={posts} heroSubtitle={heroSubtitle} />}
    {heroTemplate === 'classic' && <HeroClassic blogName={blogName} blogDescription={blogDescription} heroBgUrl={heroBgUrl} t={t} posts={posts} heroSubtitle={heroSubtitle} />}
    {heroTemplate === 'magazine' && <HeroMagazine blogName={blogName} blogDescription={blogDescription} heroBgUrl={heroBgUrl} t={t} posts={posts} heroSubtitle={heroSubtitle} />}
    {heroTemplate === 'minimal' && <HeroMinimal blogName={blogName} blogDescription={blogDescription} heroBgUrl={heroBgUrl} t={t} posts={posts} heroSubtitle={heroSubtitle} />}
    {heroTemplate === 'split' && <HeroSplit blogName={blogName} blogDescription={blogDescription} heroBgUrl={heroBgUrl} t={t} posts={posts} heroSubtitle={heroSubtitle} />}
    {heroTemplate === 'app' && <HeroApp blogName={blogName} blogDescription={blogDescription} heroBgUrl={heroBgUrl} t={t} posts={posts} heroSubtitle={heroSubtitle} />}

    <!-- Hero / Featured Post -->
    {featuredPost && heroTemplate !== 'app' && (
      <section class="mb-14 md:mb-20 max-w-5xl mx-auto">
        <div class="mb-6 md:mb-8 flex items-center justify-between">
          <h2 class="text-2xl md:text-3xl font-black italic tracking-tighter text-slate-900 uppercase">{t.featured}</h2>
        </div>
        
        <a href={`/${featuredPost.slug || featuredPost.id}`} class={`group relative flex flex-col md:flex-row overflow-hidden ${theme.borderRadius} bg-white border border-slate-100 shadow-sm transition-all hover:shadow-2xl hover:shadow-indigo-100 hover:border-indigo-100`}>
          <div class="relative aspect-[16/9] w-full overflow-hidden md:aspect-[2/1] lg:aspect-[2.5/1]">
            {featuredImage ? (
              <img 
                src={featuredImage} 
                alt={featuredPost.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="eager"
                decoding="sync"
              />
            ) : (
              <div class="absolute inset-0 h-full w-full bg-gradient-to-br from-indigo-100 to-purple-50 flex items-center justify-center">
                <span class="text-indigo-300 font-bold text-6xl opacity-50">{featuredPost.title.substring(0, 1)}</span>
              </div>
            )}
            <div class="absolute inset-0 bg-black/20"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          </div>
            
          <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10 lg:p-12">
            <div class="mb-3 md:mb-4 flex items-center gap-2">
              <span class={`rounded-full bg-indigo-500/20 px-3 py-1 text-[10px] md:text-xs font-black uppercase tracking-wider text-indigo-300 border border-indigo-500/30 backdrop-blur-md`}>
                {t.latestPick}
              </span>
            </div>
            <h3 class="mb-3 md:mb-4 text-2xl md:text-3xl font-black leading-tight text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] transition-colors break-keep line-clamp-2 md:line-clamp-none">
              {featuredPost.title}
            </h3>
            <p class="mb-6 md:mb-8 text-sm md:text-base text-slate-200 font-medium drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)] line-clamp-2 md:line-clamp-3">
              {(featuredPost.metadata?.data?.description || featuredPost.metadata?.description || featuredPost.metadata?.data?.summary || `${featuredPost.title}에 대한 상세한 정보를 확인해보세요.`)}
            </p>
            <div class="mt-auto flex items-center justify-between">
              <span class="text-sm font-bold text-white drop-shadow-md">{t.readArticle} <span class="text-indigo-400">→</span></span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Recent Posts Grid -->
    {recentPosts.length > 0 && (
      <section>
        <div class="mb-6 md:mb-8 flex items-center justify-between">
          <h2 class="text-xl md:text-2xl font-black italic tracking-tighter text-slate-900 uppercase">{t.recentArticles}</h2>
        </div>
        
        <div class={feedClass}>
          {recentPosts.slice(0, 9).map(post => (
            <div class="break-inside-avoid">
              <PostCard post={post} />
            </div>
          ))}
        </div>
        
        {recentPosts.length > 9 && (
          <div class="mt-12 text-center">
            <a href="/page/2" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-8 py-3 text-sm font-bold text-slate-700 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700 hover:shadow-md">
              {t.loadMore}
            </a>
          </div>
        )}
      </section>
    )}

    <!-- Category Explore Section (AdSense Internal Linking) -->
    {posts.length > 0 && (
      <section class="mt-16 md:mt-24 border-t border-slate-200 pt-16">
        <div class="mb-8 text-center">
          <h2 class="text-2xl md:text-3xl font-black tracking-tight text-slate-900 mb-4">{lang === 'ko' ? '주제별로 탐색하기' : (lang === 'ja' ? 'カテゴリーで探す' : 'Explore by Category')}</h2>
          <p class="text-slate-500 max-w-2xl mx-auto">
            {lang === 'ko' ? '관심 있는 분야의 심도 깊은 인사이트와 가이드를 만나보세요.' : (lang === 'ja' ? '興味のある分野の深い洞察とガイドをご覧ください。' : 'Find deep insights and guides in your areas of interest.')}
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-4">
          {Array.from(new Set(posts.map(p => p.metadata?.category).filter(Boolean))).slice(0, 8).map(category => (
            <a href={`/category/${encodeURIComponent(category as string)}`} class="px-6 py-3 bg-slate-50 hover:bg-indigo-50 border border-slate-200 hover:border-indigo-200 rounded-xl text-slate-700 hover:text-indigo-700 font-bold transition-colors">
              <span class="capitalize">{category}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {posts.length === 0 && (
      <div class="overflow-hidden rounded-[32px] border border-slate-200/80 bg-white/90 px-8 py-14 text-center shadow-sm md:px-12">
        <div class="mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-slate-100 to-indigo-100 text-slate-400 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </div>
        <h2 class="mb-3 text-2xl font-black tracking-tight text-slate-900">{t.emptyTitle}</h2>
        <p class="mx-auto max-w-xl text-slate-500">
          {t.emptyDesc}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/about" class="rounded-full bg-indigo-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-200 transition-transform hover:-translate-y-0.5">{t.emptyAbout}</a>
          <a href="/contact" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-700 transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700">{t.emptyContact}</a>
        </div>
      </div>
    )}

  </div>
</Layout>
