---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getSiteConfig, getRequestDomain } from '../lib/api';

const domain = getRequestDomain(Astro.request);
const siteConfig = await getSiteConfig(domain);
const blogName = siteConfig?.blog_name || "Maza Blog";
---
<Layout title="Disclaimer" description={`${blogName} Disclaimer`}>
  <main class="mx-auto max-w-4xl px-6 py-20 md:py-24 relative">
    <div class="absolute top-0 right-0 w-full h-96 bg-gradient-to-b from-slate-100 to-transparent -z-10"></div>

    <div class="mb-12 border-b border-slate-200 pb-12">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-orange-50 px-4 py-2 text-sm font-bold uppercase tracking-widest text-orange-600 border border-orange-100">
        Legal
      </div>
      <h1 class="text-4xl font-black leading-tight tracking-tight text-slate-900 md:text-5xl">
        Disclaimer
      </h1>
      <p class="mt-4 text-slate-500 font-medium">Please read this disclaimer carefully before using our website.</p>
    </div>

    <div class="prose prose-lg prose-slate max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-indigo-600 hover:prose-a:text-indigo-700">
      <div class="rounded-3xl border border-orange-200 bg-orange-50/50 p-8 mb-10">
        <h2 class="text-xl font-bold text-orange-900 m-0 mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
          일반 정보 제공 목적
        </h2>
        <p class="text-orange-800 m-0 leading-relaxed">
          <strong>{blogName}</strong>에서 제공하는 모든 정보와 콘텐츠는 일반적인 정보 제공만을 목적으로 하며, 어떠한 형태의 법적, 재무적, 의학적 또는 기타 전문적인 조언을 대체할 수 없습니다. 본 사이트의 정보를 바탕으로 내린 결정에 대한 모든 책임은 사용자 본인에게 있습니다.
        </p>
      </div>

      <h3>수익 창출 고지 (Affiliate & Advertising Disclosure)</h3>
      <p>
        본 사이트는 지속적인 운영을 위해 다양한 제휴 마케팅 프로그램 및 광고 네트워크(예: 구글 애드센스, 쿠팡 파트너스 등)에 참여하고 있습니다.
      </p>
      <ul>
        <li>사이트 내의 일부 링크를 통해 제품이나 서비스를 구매하실 경우, 본 사이트가 소정의 수수료를 지급받을 수 있습니다.</li>
        <li>이러한 제휴 수수료는 사용자의 구매 가격에 어떠한 영향도 미치지 않습니다.</li>
        <li>게재된 외부 광고의 내용이나 연결된 사이트의 정책에 대해 본 사이트는 책임을 지지 않습니다.</li>
      </ul>

      <h3>콘텐츠의 정확성 및 AI 활용</h3>
      <p>
        우리는 가장 정확하고 최신의 정보를 제공하기 위해 노력합니다. 일부 콘텐츠의 초안 작성이나 자료 수집 과정에서 AI 기술이 보조 도구로 활용될 수 있으며, 발행 전 전문가 또는 편집자의 검수 과정을 거칩니다. 그러나 모든 정보의 완전성이나 시의성을 보장할 수는 없으므로 참고용으로만 활용해 주시기 바랍니다.
      </p>
    </div>
  </main>
</Layout>
