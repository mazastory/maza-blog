---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getApprovedPosts, getRequestDomain } from '../../lib/api';

// 캐시 설정으로 로딩 속도 대폭 개선 (SWR 적용)
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=60, stale-while-revalidate=86400, stale-if-error=86400');
Astro.response.headers.set('Netlify-CDN-Cache-Control', 'public, max-age=0, s-maxage=60, stale-while-revalidate=86400, stale-if-error=86400');

const domain = getRequestDomain(Astro.request);
const { slug } = Astro.params;

if (!slug) {
  return Astro.rewrite('/404');
}

const decodedSlug = decodeURIComponent(slug);
const allPosts = await getApprovedPosts(domain, Astro.locals.lang || 'ko');

// 카테고리 필터링: 대소문자 무시 매칭
let categoryPosts = allPosts.filter(post => {
  const category = post.metadata?.category || '';
  return category.toLowerCase() === decodedSlug.toLowerCase();
});

// 만약 해당 카테고리의 포스트가 없고, 현재 요청한 카테고리가 사이트 기본 카테고리와 일치한다면
// 카테고리가 지정되지 않은(undefined/빈 문자열) 포스트들을 기본 카테고리로 간주하여 보여줍니다.
if (categoryPosts.length === 0) {
  const { getSiteConfig } = await import('../../lib/api');
  const siteConfig = await getSiteConfig(domain);
  const fallbackCategory = siteConfig?.metadata?.primary_topic_ko || 'Trend';
  
  if (decodedSlug.toLowerCase() === fallbackCategory.toLowerCase()) {
    categoryPosts = allPosts.filter(post => !post.metadata?.category);
  }
}

// 카테고리별 동적 설명 (SEO용 Thin Content 방어)
const categoryDescriptions: Record<string, string> = {
  'it': '최신 테크 트렌드, 소프트웨어 가이드, 그리고 유용한 IT 실무 팁을 깊이 있게 분석합니다.',
  'health': '검증된 논문과 전문가 자료를 바탕으로 올바른 건강 관리 및 다이어트 정보를 제공합니다.',
  'finance': '재테크 노하우, 자산 관리 전략, 그리고 최신 경제 흐름을 쉽게 풀어냅니다.',
  'travel': '생생한 여행 경험과 실용적인 현지 가이드, 그리고 추천 명소 정보를 공유합니다.',
  'life': '더 나은 일상을 위한 생활 꿀팁, 자기계발, 그리고 다양한 라이프스타일 인사이드를 나눕니다.'
};

const defaultDescription = `이 카테고리에서는 '${slug}'와 관련된 깊이 있고 실용적인 정보를 다룹니다. 최신 동향과 실전 적용 팁을 확인해 보세요.`;
const currentDesc = categoryDescriptions[slug.toLowerCase()] || defaultDescription;

---

<Layout title={`${slug} 카테고리`} description={`${slug} 카테고리에 해당하는 글 모음입니다.`}>
  <div class="mx-auto max-w-5xl px-6 pt-12 pb-20 md:pt-20">
    
    <header class="mb-14 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-bold text-indigo-600 border border-indigo-100">
        Category Collection
      </div>
      <h1 class="text-4xl font-black tracking-tight text-slate-900 md:text-5xl capitalize">
        {slug}
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 leading-relaxed font-medium">
        {currentDesc}
      </p>
      <p class="mt-4 text-sm text-slate-400">
        총 {categoryPosts.length}개의 전문 포스트가 등록되어 있습니다.
      </p>
    </header>

    {categoryPosts.length > 0 ? (
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {categoryPosts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="py-20 text-center">
        <p class="text-slate-500">해당 카테고리에 작성된 글이 없습니다.</p>
      </div>
    )}
  </div>
</Layout>
