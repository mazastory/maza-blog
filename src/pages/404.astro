---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
Astro.response.status = 404;
---

<Layout title="페이지를 찾을 수 없습니다 (404)">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <h1 class="text-9xl font-black text-indigo-600 mb-4">404</h1>
    <h2 class="text-3xl font-bold text-slate-800 mb-4">페이지를 찾을 수 없습니다</h2>
    <p class="text-slate-500 mb-8 max-w-md">
      요청하신 페이지가 삭제되었거나, 이름이 변경되었거나, 일시적으로 사용할 수 없습니다.
    </p>
    <a href="/" class="px-6 py-3 bg-indigo-600 text-white font-semibold rounded-xl shadow-md hover:bg-indigo-700 transition-colors">
      홈으로 돌아가기
    </a>
  </div>
</Layout>
