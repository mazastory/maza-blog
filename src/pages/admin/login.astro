---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Login - Maza Blog">
  <div class="min-h-[80vh] flex items-center justify-center bg-slate-50 px-4">
    <div class="max-w-md w-full bg-white rounded-3xl shadow-xl border border-slate-100 p-8 md:p-12">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">Admin Login</h1>
        <p class="text-slate-500 mt-2 font-medium">관리자 계정으로 로그인하세요.</p>
      </div>

      <form id="login-form" class="space-y-5">
        <div>
          <label class="block text-xs font-bold text-slate-700 mb-1.5">이메일</label>
          <input 
            type="email" 
            id="email" 
            required
            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all font-medium"
            placeholder="admin@example.com"
          />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 mb-1.5">비밀번호</label>
          <input 
            type="password" 
            id="password" 
            required
            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all font-medium"
            placeholder="••••••••"
          />
        </div>
        
        <div id="error-msg" class="hidden text-sm text-red-500 font-bold bg-red-50 p-3 rounded-xl"></div>

        <button 
          type="submit" 
          id="submit-btn"
          class="w-full py-4 mt-4 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition-colors flex items-center justify-center gap-2"
        >
          <span>로그인</span>
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    
    errorMsg.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '로그인 중...';
    
    try {
      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) throw error;
      
      // 로그인 성공 시 대시보드로 이동
      window.location.href = '/admin';
    } catch (err: any) {
      errorMsg.textContent = err.message || '로그인에 실패했습니다.';
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.innerHTML = '로그인';
    }
  });

  // 이미 로그인되어 있으면 튕겨냄
  supabase.auth.getSession().then(({ data }) => {
    if (data.session) {
      window.location.href = '/admin';
    }
  });
</script>
