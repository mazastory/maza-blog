---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Dashboard - Maza Blog">
  <div class="mx-auto max-w-5xl px-4 py-12">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4">
      <div>
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">블로그 관리자</h1>
        <p class="text-slate-500 font-medium mt-1">이곳에서 마자 스튜디오 없이도 내 블로그 글을 직접 관리할 수 있습니다.</p>
      </div>
      <div class="flex items-center gap-3">
        <a href="/admin/editor" class="px-5 py-2.5 bg-indigo-600 text-white rounded-xl font-bold shadow-md hover:bg-indigo-700 transition-colors">
          + 새 글 쓰기
        </a>
        <button id="logout-btn" class="px-4 py-2.5 bg-slate-100 text-slate-600 rounded-xl font-bold hover:bg-slate-200 transition-colors">
          로그아웃
        </button>
      </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="p-6 border-b border-slate-100 bg-slate-50">
        <h2 class="text-lg font-bold text-slate-800">전체 게시글</h2>
      </div>
      
      <div id="loading" class="p-12 text-center text-slate-400 font-medium">
        게시글을 불러오는 중...
      </div>
      
      <div id="empty-state" class="hidden p-12 text-center">
        <div class="text-4xl mb-4">📝</div>
        <h3 class="text-lg font-bold text-slate-700 mb-2">작성된 글이 없습니다</h3>
        <p class="text-slate-500 mb-6">첫 번째 수동 글을 작성해보세요!</p>
        <a href="/admin/editor" class="px-5 py-2 bg-indigo-50 text-indigo-600 rounded-lg font-bold hover:bg-indigo-100">글쓰기</a>
      </div>

      <ul id="post-list" class="divide-y divide-slate-100">
        <!-- Posts will be injected here via JS -->
      </ul>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';

  // Auth Check
  supabase.auth.getSession().then(({ data }) => {
    if (!data.session) {
      window.location.href = '/admin/login';
    } else {
      loadPosts();
    }
  });

  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/admin/login';
  });

  async function loadPosts() {
    const loading = document.getElementById('loading');
    const emptyState = document.getElementById('empty-state');
    const postList = document.getElementById('post-list');
    
    // 현재 접속된 도메인을 기준으로 사이트 조회 (옵션)
    const _domain = window.location.hostname;
    
    try {
      // 내 DB의 posts 테이블에서 모든 글 가져오기
      const { data: posts, error } = await supabase
        .from('posts')
        .select('id, title, status, created_at, publish_at, slug')
        .order('created_at', { ascending: false });

      if (error) throw error;

      if (loading) loading.style.display = 'none';

      if (!posts || posts.length === 0) {
        if (emptyState) emptyState.classList.remove('hidden');
        return;
      }

      if (postList) {
        postList.innerHTML = posts.map((post: any) => `
          <li class="p-6 hover:bg-slate-50 transition-colors flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-widest ${
                  post.status === 'published' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'
                }">
                  ${post.status || 'draft'}
                </span>
                <span class="text-xs text-slate-400 font-medium">${new Date(post.publish_at || post.created_at).toLocaleDateString()}</span>
              </div>
              <h3 class="text-base font-bold text-slate-900 line-clamp-1">
                <a href="/${post.slug || post.id}" target="_blank" class="hover:text-indigo-600 transition-colors">
                  ${post.title}
                </a>
              </h3>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a href="/admin/editor?id=${post.id}" class="px-3 py-1.5 bg-white border border-slate-200 text-slate-600 rounded-lg text-sm font-bold hover:border-indigo-300 hover:text-indigo-600 transition-colors">
                수정
              </a>
              <button onclick="deletePost('${post.id}')" class="px-3 py-1.5 bg-white border border-slate-200 text-red-500 rounded-lg text-sm font-bold hover:bg-red-50 hover:border-red-200 transition-colors">
                삭제
              </button>
            </div>
          </li>
        `).join('');
      }
    } catch (err: any) {
      alert('게시글을 불러오지 못했습니다: ' + err.message);
    }
  }

  // 글로벌 함수로 노출
  (window as any).deletePost = async (id: string) => {
    if (!confirm('정말로 이 글을 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다.')) return;
    
    try {
      const { error } = await supabase.from('posts').delete().eq('id', id);
      if (error) throw error;
      
      alert('삭제되었습니다.');
      window.location.reload();
    } catch(e: any) {
      alert('삭제 실패: ' + e.message);
    }
  };
</script>
