---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getSiteConfig } from '../lib/api';

const siteConfig = await getSiteConfig();
const blogName = siteConfig?.blog_name || "Maza Blog";
---
<Layout title={`About ${blogName}`} description={`About ${blogName}`}>
  <main class="mx-auto max-w-4xl px-6 py-20 md:py-32 relative">
    <!-- Background Decorators -->
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-indigo-200/30 rounded-full blur-[100px] -z-10"></div>
    <div class="absolute top-48 -right-24 w-96 h-96 bg-sky-200/30 rounded-full blur-[100px] -z-10"></div>

    <div class="overflow-hidden rounded-[40px] border border-slate-200/80 bg-white/60 backdrop-blur-2xl p-10 md:p-16 shadow-[0_32px_80px_-48px_rgba(79,70,229,0.3)]">
      <div class="mb-8 inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-2 text-sm font-bold uppercase tracking-widest text-indigo-600 border border-indigo-100">
        About Us
      </div>
      
      <h1 class="mb-10 text-4xl font-black leading-tight tracking-tight text-slate-900 md:text-5xl lg:text-6xl break-keep">
        Welcome to <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-sky-500">{blogName}</span>
      </h1>
      
      <div class="prose prose-lg md:prose-xl prose-slate max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-indigo-600 hover:prose-a:text-indigo-700 prose-p:leading-relaxed">
        <p class="text-xl font-medium text-slate-600">
          <strong>{blogName}</strong>는 전문 분야별 서브도메인으로 운영되는 프리미엄 SEO 최적화 블로그 플랫폼입니다. 각 서브도메인은 독립적인 niche 사이트로서 높은 검색 엔진 가시성을 목표로 합니다.
        </p>
        <div class="my-12 h-px w-full bg-gradient-to-r from-transparent via-slate-200 to-transparent"></div>
        <p>
          본 사이트는 독자 여러분께 가장 정확하고 가치 있는 정보를 전달하기 위해 운영됩니다. 광고 수익(구글 애드센스, 파트너스 등)과 자체 콘텐츠를 제공하며, 모든 콘텐츠는 Maza AI 기술의 초안을 바탕으로 <strong>전문 편집자의 깐깐한 검수와 수정</strong>을 거쳐 발행됩니다.
        </p>
        <div class="mt-12 flex flex-wrap gap-4">
          <a href="/contact" class="inline-flex items-center justify-center rounded-full bg-slate-950 px-8 py-4 text-sm font-bold text-white shadow-lg shadow-slate-900/20 transition-all hover:-translate-y-1 hover:shadow-xl hover:bg-indigo-600">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
