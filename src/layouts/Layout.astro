---
import '../styles/global.css';
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import DynamicTheme from '../components/DynamicTheme.astro';
import { getSiteConfig, getRequestDomain, getApprovedPosts } from '../lib/api';
import { generateThemeVars } from '../lib/theme';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	authorName?: string;
	datePublished?: string;
  preloadImage?: string;
  siteConfig?: any;
}

const domain = getRequestDomain(Astro.request);
const siteConfig = Astro.props.siteConfig || await getSiteConfig(domain);
const theme = generateThemeVars(siteConfig);
const allPosts = await getApprovedPosts(domain, Astro.locals.lang);
const uniqueCategories = Array.from(new Set(allPosts.map(p => p.metadata?.category).filter(Boolean)));
// CDN 캐시 강화: 1시간 CDN + 24시간 stale-while-revalidate
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=86400');
const siteTitle = siteConfig?.blog_name || "Maza Blog";
const siteDesc = siteConfig?.niche || "MazaStudio Subdomain Blog - High Quality AI Content";

const { 
	title, 
	description = siteDesc, 
	image, 
	type = 'website',
	authorName = siteTitle,
	datePublished,
	preloadImage = undefined
} = Astro.props;

const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const canonicalUrl = Astro.url.href;

const rawSc = siteConfig?.sc_verification || siteConfig?.metadata?.google_site_verification || '';
let scContent = rawSc;
if (rawSc) {
  const match = rawSc.match(/content="([^"]+)"/);
  scContent = match ? match[1] : rawSc.replace('google-site-verification=', '');
}
---

<!doctype html>
<html lang={siteConfig?.metadata?.lang || "ko"} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		{/* Google Fonts — 비동기 로드 (렌더 블로킹 제거) */}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
		</noscript>
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
			{preloadImage && (
				<link rel="preload" as="image" href={preloadImage} />
			)}
		<SEO 
			title={pageTitle} 
			description={description} 
			image={image} 
			canonicalUrl={canonicalUrl} 
			type={type} 
		/>
		
		<Schema 
			type={type === 'article' ? 'Article' : 'WebSite'}
			title={pageTitle}
			description={description}
			url={canonicalUrl}
			image={image}
			authorName={authorName}
			datePublished={datePublished}
		/>
		<DynamicTheme siteConfig={siteConfig} />

		{siteConfig?.adsense_pub && siteConfig?.purpose !== 'monetization' && (
			<script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${siteConfig.adsense_pub.startsWith('ca-pub-') ? siteConfig.adsense_pub : `ca-${siteConfig.adsense_pub.startsWith('pub-') ? siteConfig.adsense_pub : `pub-${siteConfig.adsense_pub}`}`}`} crossorigin="anonymous"></script>
		)}

		{/* 구글 서치콘솔 소유권 인증 메타 태그 */}
		{scContent && (
			<meta name="google-site-verification" content={scContent} />
		)}

		{/* 구글 애널리틱스 (GA4) */}
		{siteConfig?.ga_measurement_id && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.ga_measurement_id}`}></script>
				<script is:inline define:vars={{ gaId: siteConfig.ga_measurement_id }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}

		{/* RSS 자동 검색(autodiscovery)용 링크 */}
		<link rel="alternate" type="application/rss+xml" title={`${siteTitle} RSS Feed`} href="/rss.xml" />
	</head>
	<body class="relative overflow-x-hidden bg-slate-50 text-slate-900 antialiased selection:bg-indigo-100 selection:text-indigo-900 flex flex-col min-h-screen">
		<div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,_rgba(79,70,229,0.12),_transparent_30%),radial-gradient(circle_at_top_right,_rgba(14,165,233,0.1),_transparent_28%),linear-gradient(to_bottom,_rgba(255,255,255,0.92),_rgba(248,250,252,1))]"></div>
		<Header siteConfig={siteConfig} categories={uniqueCategories} currentLang={Astro.locals.lang || 'ko'} />
		
		<main class="relative z-10 flex-1">
			<slot />
		</main>

		
    <!-- Dynamic Footer -->
    <footer class={`relative z-10 border-t ${theme.footerBg === 'black' ? 'bg-black text-slate-400 border-black' : theme.footerBg === 'dark' ? 'bg-slate-900 text-slate-400 border-slate-800' : theme.footerBg === 'light' ? 'bg-slate-50 text-slate-500 border-slate-200' : 'bg-white text-slate-500 border-slate-100'} ${theme.paddingY} mt-16`}>
      <div class={`mx-auto px-6 ${theme.layoutWidth} ${theme.footerCols > 1 ? 'grid gap-8' : 'flex flex-col'} ${theme.footerCols === 2 ? 'grid-cols-1 md:grid-cols-2' : theme.footerCols === 3 ? 'grid-cols-1 md:grid-cols-3' : theme.footerCols === 4 ? 'grid-cols-1 sm:grid-cols-2 md:grid-cols-4' : ''} ${theme.footerAlign === 'center' ? 'text-center items-center' : 'text-left'}`}>
        
        {/* Col 1: Brand */}
        <div class={`flex flex-col ${theme.footerAlign === 'center' ? 'items-center' : 'items-start'}`}>
          <h3 class="text-xl font-black mb-4">{siteTitle}</h3>
          <p class="text-sm opacity-80 mb-6 max-w-xs">{siteDesc}</p>
          <p class="text-xs opacity-60">© {new Date().getFullYear()} {siteTitle}. All rights reserved.</p>
        </div>

        {/* Col 2: Quick Links */}
        {theme.footerCols >= 2 && (
          <div class={`flex flex-col ${theme.footerAlign === 'center' ? 'items-center' : 'items-start'}`}>
            <h4 class="font-bold mb-4 uppercase text-sm tracking-wider">Quick Links</h4>
            <ul class="space-y-2 text-sm opacity-80">
              <li><a href="/about" class="hover:text-[var(--color-indigo-600)] transition-colors">About Us</a></li>
              <li><a href="/contact" class="hover:text-[var(--color-indigo-600)] transition-colors">Contact</a></li>
            </ul>
          </div>
        )}

        {/* Col 3: Legal */}
        {theme.footerCols >= 3 && (
          <div class={`flex flex-col ${theme.footerAlign === 'center' ? 'items-center' : 'items-start'}`}>
            <h4 class="font-bold mb-4 uppercase text-sm tracking-wider">Legal</h4>
            <ul class="space-y-2 text-sm opacity-80">
              <li><a href="/privacy" class="hover:text-[var(--color-indigo-600)] transition-colors">Privacy Policy</a></li>
              <li><a href="/disclaimer" class="hover:text-[var(--color-indigo-600)] transition-colors">Disclaimer</a></li>
              <li><a href="/rss.xml" class="hover:text-[var(--color-indigo-600)] transition-colors">RSS Feed</a></li>
            </ul>
          </div>
        )}

        {/* Col 4: Categories */}
        {theme.footerCols >= 4 && (
          <div class={`flex flex-col ${theme.footerAlign === 'center' ? 'items-center' : 'items-start'}`}>
            <h4 class="font-bold mb-4 uppercase text-sm tracking-wider">Categories</h4>
            <ul class="space-y-2 text-sm opacity-80">
              {uniqueCategories.slice(0, 3).map((cat: string) => (
                <li><a href={`/category/${encodeURIComponent(cat)}`} class="hover:text-[var(--color-indigo-600)] uppercase">{cat}</a></li>
              ))}
            </ul>
          </div>
        )}

      </div>
      
      {theme.footerCols === 1 && (
        <div class="w-full border-t border-current opacity-20 mt-8 pt-8">
          <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs font-semibold">
            <a href="/about" class="hover:text-[var(--color-indigo-600)] transition-colors">About</a>
            <a href="/contact" class="hover:text-[var(--color-indigo-600)] transition-colors">Contact</a>
            <a href="/privacy" class="hover:text-[var(--color-indigo-600)] transition-colors">Privacy</a>
            <a href="/disclaimer" class="hover:text-[var(--color-indigo-600)] transition-colors">Disclaimer</a>
          </nav>
        </div>
      )}
    </footer>
  </body>
</html>
