---
import { Search } from 'lucide-astro';
import { generateThemeVars } from '../lib/theme';

interface Props {
  siteConfig?: any;
  categories?: string[];
  currentLang?: string;
}

const { siteConfig = null, categories = [], currentLang = 'ko' } = Astro.props;
const blogName = siteConfig?.blog_name || "Maza Blog";
const theme = generateThemeVars(siteConfig);
---

{theme.headerStyle === 'banner' && (
  <div class="w-full bg-[var(--color-indigo-600)] text-indigo-50 py-2 text-center text-xs font-bold tracking-wider uppercase">
    Welcome to {blogName}
  </div>
)}

<header class={`sticky top-0 z-50 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md transition-all ${theme.headerStyle === 'center' ? 'py-4' : ''}`}>
  <div class={`mx-auto flex h-16 ${theme.layoutWidth} items-center justify-between px-6 ${theme.headerStyle === 'center' ? 'flex-col justify-center h-auto gap-4' : ''}`}>
    <a href="/" class="flex items-center gap-2">
      <div class={`flex h-8 w-8 items-center justify-center ${theme.borderRadius} bg-[var(--color-indigo-600)] text-white font-bold shadow-lg shadow-[var(--color-indigo-200)]`}>
        {blogName.charAt(0).toUpperCase()}
      </div>
      <span class="text-xl font-black italic tracking-tight text-[var(--color-indigo-700)]">
        {blogName}
      </span>
    </a>

    <nav class={`hidden md:flex items-center gap-8 text-sm font-semibold text-slate-600 ${theme.headerStyle === 'center' ? 'w-full justify-center border-t border-slate-100 pt-4' : ''}`}>
      <a href="/" class="hover:text-[var(--color-indigo-600)] transition-colors">Home</a>
      {categories.map((cat: string) => (
        <a href={`/category/${encodeURIComponent(cat)}`} class="hover:text-[var(--color-indigo-600)] transition-colors uppercase">{cat}</a>
      ))}
      <a href="/about" class="hover:text-[var(--color-indigo-600)] transition-colors">About</a>
    </nav>

    <div class={`flex items-center gap-4 ${theme.headerStyle === 'center' ? 'absolute right-6 top-6' : ''}`}>
      <!-- Language Switcher -->
      <div class="hidden sm:flex items-center gap-2 text-xs font-semibold text-slate-500">
        <a href="/" class={`transition-colors ${currentLang === 'ko' ? 'text-[var(--color-indigo-600)] font-black' : 'hover:text-[var(--color-indigo-600)]'}`}>KR</a>
        <span class="text-slate-300">|</span>
        <a href="/en" class={`transition-colors ${currentLang === 'en' ? 'text-[var(--color-indigo-600)] font-black' : 'hover:text-[var(--color-indigo-600)]'}`}>EN</a>
        <span class="text-slate-300">|</span>
        <a href="/ja" class={`transition-colors ${currentLang === 'ja' ? 'text-[var(--color-indigo-600)] font-black' : 'hover:text-[var(--color-indigo-600)]'}`}>JA</a>
      </div>

      <button class={`p-2 text-slate-400 hover:text-[var(--color-indigo-600)] transition-colors ${theme.borderRadius} hover:bg-[var(--color-indigo-50)]`}>
        <Search size={20} />
      </button>
    </div>
  </div>
</header>
