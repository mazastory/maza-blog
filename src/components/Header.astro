---
import { Search } from 'lucide-astro';
import { generateThemeVars } from '../lib/theme';

interface Props {
  siteConfig?: any;
  categories?: string[];
  currentLang?: string;
}

const { siteConfig = null, categories = [], currentLang = 'ko' } = Astro.props;
const blogName = siteConfig?.blog_name || "Maza Blog";
const theme = generateThemeVars(siteConfig);

const darkBg = theme.headerDarkMode ? 'bg-slate-900 border-slate-800 text-white' : 'bg-white/80 border-slate-200 backdrop-blur-md';
const textNav = theme.headerDarkMode ? 'text-slate-300' : 'text-slate-600';
---

{theme.headerTopBar && (
  <div class={`w-full ${theme.headerDarkMode ? 'bg-indigo-900 text-indigo-100' : 'bg-[var(--color-indigo-600)] text-indigo-50'} py-2 text-center text-xs font-bold tracking-wider uppercase`}>
    Welcome to {blogName}
  </div>
)}

<header class={`sticky top-0 z-50 w-full border-b transition-all ${darkBg} ${theme.paddingY}`}>
  <div class={`mx-auto flex flex-col md:flex-row items-center justify-between px-6 gap-4 ${theme.layoutWidth} ${theme.headerMenuPos === 'bottom' ? 'md:flex-col' : ''}`}>
    
    {theme.headerLogoPos === 'left' && theme.headerMenuPos !== 'bottom' && (
      <div class="flex-1 flex justify-start">
        <a href="/" class="flex items-center gap-2">
          <div class={`flex h-8 w-8 items-center justify-center ${theme.borderRadius} bg-[var(--color-indigo-600)] text-white font-bold shadow-lg shadow-[var(--color-indigo-200)]`}>{blogName.charAt(0).toUpperCase()}</div>
          <span class="text-xl font-black italic tracking-tight">{blogName}</span>
        </a>
      </div>
    )}

    {theme.headerLogoPos === 'center' && theme.headerMenuPos !== 'bottom' && (
      <div class="flex-1 flex justify-start">
        <nav class={`hidden md:flex items-center gap-6 text-sm font-semibold ${textNav}`}>
          <a href="/" class="hover:text-[var(--color-indigo-600)]">Home</a>
          {categories.map((cat: string) => (<a href={`/category/${encodeURIComponent(cat)}`} class="hover:text-[var(--color-indigo-600)] uppercase">{cat}</a>))}
        </nav>
      </div>
    )}

    {theme.headerLogoPos === 'center' && theme.headerMenuPos !== 'bottom' && (
      <div class="flex-none">
        <a href="/" class="flex items-center gap-2">
          <span class="text-2xl font-black uppercase tracking-tighter text-[var(--color-indigo-600)]">{blogName}</span>
        </a>
      </div>
    )}

    {theme.headerLogoPos === 'left' && theme.headerMenuPos !== 'bottom' && (
      <div class={`flex-auto flex ${theme.headerMenuPos === 'right' ? 'justify-end pr-8' : 'justify-center'}`}>
        <nav class={`hidden md:flex items-center gap-6 text-sm font-semibold ${textNav}`}>
          <a href="/" class="hover:text-[var(--color-indigo-600)]">Home</a>
          {categories.map((cat: string) => (<a href={`/category/${encodeURIComponent(cat)}`} class="hover:text-[var(--color-indigo-600)] uppercase">{cat}</a>))}
          <a href="/about" class="hover:text-[var(--color-indigo-600)]">About</a>
        </nav>
      </div>
    )}

    {theme.headerLogoPos === 'right' && theme.headerMenuPos !== 'bottom' && (
      <>
        <div class="flex-1 flex justify-start gap-8">
          <nav class={`hidden md:flex items-center gap-6 text-sm font-semibold ${textNav}`}>
            {categories.map((cat: string) => (<a href={`/category/${encodeURIComponent(cat)}`} class="hover:text-[var(--color-indigo-600)] uppercase">{cat}</a>))}
          </nav>
        </div>
        <div class="flex-none">
          <a href="/" class="flex items-center gap-2 text-xl font-black">{blogName}</a>
        </div>
      </>
    )}

    {theme.headerMenuPos !== 'bottom' && (
      <div class="flex-1 flex justify-end items-center gap-4">
        <div class="hidden sm:flex items-center gap-2 text-xs font-semibold text-slate-500">
          <a href="/" class={currentLang === 'ko' ? 'text-[var(--color-indigo-600)]' : ''}>KR</a>
          <span>|</span>
          <a href="/en" class={currentLang === 'en' ? 'text-[var(--color-indigo-600)]' : ''}>EN</a>
        </div>
        <button class="p-2 text-slate-400 hover:text-[var(--color-indigo-600)] transition-colors"><Search size={20} /></button>
      </div>
    )}

    {theme.headerMenuPos === 'bottom' && (
      <>
        <div class="w-full flex justify-between items-center">
          {theme.headerLogoPos === 'center' ? <div class="flex-1"></div> : null}
          <a href="/" class={`flex items-center gap-2 text-2xl font-black ${theme.headerLogoPos === 'right' ? 'ml-auto' : ''}`}>
            {blogName}
          </a>
          <div class={`flex-1 flex justify-end gap-4`}>
            <button class="p-2 text-slate-400"><Search size={20} /></button>
          </div>
        </div>
        <div class={`w-full flex ${theme.headerLogoPos === 'center' ? 'justify-center' : 'justify-start'} border-t ${theme.headerDarkMode ? 'border-slate-800' : 'border-slate-100'} pt-4 mt-2`}>
          <nav class={`hidden md:flex items-center gap-8 text-sm font-semibold ${textNav}`}>
            <a href="/" class="hover:text-[var(--color-indigo-600)]">Home</a>
            {categories.map((cat: string) => (<a href={`/category/${encodeURIComponent(cat)}`} class="hover:text-[var(--color-indigo-600)] uppercase">{cat}</a>))}
          </nav>
        </div>
      </>
    )}

  </div>
</header>
