---
export interface Props {
  blogName: string;
  blogDescription: string;
  heroBgUrl?: string | null;
  t: any;
  posts: any[];
  heroSubtitle: string;
}
const { blogName, blogDescription, heroBgUrl, t, posts, heroSubtitle } = Astro.props;
---

<section class="relative mb-10 md:mb-16 py-16 md:py-24">
  <div class="max-w-4xl">
    <div class="mb-8 flex items-center gap-4">
      <div class="w-12 h-[2px] bg-black"></div>
      <span class="text-sm font-black uppercase tracking-[0.2em] text-slate-900">
        {blogName}
      </span>
    </div>
    <h1 class={`${blogDescription.length > 40 ? 'text-4xl md:text-5xl lg:text-6xl' : 'text-5xl md:text-7xl lg:text-8xl'} font-black tracking-tighter text-slate-900 leading-[1.1] break-keep`} style="word-break: keep-all; overflow-wrap: break-word;">
      {blogDescription}
    </h1>
    <p class="mt-8 text-xl md:text-2xl lg:text-3xl font-medium leading-relaxed text-slate-500 tracking-tight break-keep max-w-4xl">
      {heroSubtitle}
    </p>
    <div class="mt-12">
      <a href="/about" class="inline-flex items-center justify-center bg-black px-10 py-4 text-sm font-bold tracking-widest text-white uppercase hover:bg-slate-800 transition-colors">
        {t.about}
      </a>
    </div>
  </div>
</section>
