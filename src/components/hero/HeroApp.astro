---
export interface Props {
  blogName: string;
  blogDescription: string;
  heroBgUrl?: string | null;
  t: any;
  posts: any[];
  heroSubtitle: string;
}
const { blogName, blogDescription, heroBgUrl, t, posts, heroSubtitle } = Astro.props;

let bgImg = heroBgUrl || '/hero-bg-picasso.png';
if (!heroBgUrl && posts.length > 0) {
  const metaImg = posts[0].metadata?.data?.image1 
    || posts[0].metadata?.blocks?.find((b: any) => b.type === 'image')?.url
    || posts[0].metadata?.thumbnail_url
    || posts[0].thumbnail_url
    || null;
  if (metaImg) bgImg = metaImg;
}

// 상단 캐러셀용 최신 포스트 5개
const carouselPosts = posts.slice(0, 5);
---

<section class="relative mb-16 md:mb-24 -mx-4 md:-mx-6 -mt-8 md:-mt-20">
  <!-- Full Bleed Dark Hero Background -->
  <div class="absolute inset-0 bg-slate-900 rounded-[32px] md:rounded-[48px] overflow-hidden">
    <img src={bgImg} alt="App Hero" class="w-full h-full object-cover opacity-80" />
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/70 to-slate-900/30"></div>
  </div>

  <div class="relative z-10 pt-28 md:pt-36 pb-32 md:pb-40 px-4 md:px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-2">
        <span class="text-xs font-black uppercase tracking-[0.2em] text-white/80">
          {blogName}
        </span>
      </div>
      <h1 class={`${blogDescription.length > 40 ? 'text-3xl md:text-4xl' : 'text-4xl md:text-5xl lg:text-6xl'} font-black tracking-tight text-white leading-tight break-keep mb-4 shadow-sm`} style="word-break: keep-all; overflow-wrap: break-word;">
        {blogDescription}
      </h1>
      <p class="text-white/70 font-medium text-lg max-w-xl break-keep">
        {heroSubtitle}
      </p>
    </div>
  </div>

  <!-- Overlapping Bottom Sheet -->
  <div class="relative z-20 -mt-24 md:-mt-32 bg-white rounded-[32px] md:rounded-[48px] pt-10 pb-12 shadow-[0_10px_40px_rgba(0,0,0,0.08)] border border-slate-100">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <div class="mb-6 flex items-end justify-between">
        <h2 class="text-xl md:text-2xl font-black text-slate-900 tracking-tight">NEW</h2>
        <span class="text-sm font-bold text-slate-400">최신 포스트</span>
      </div>
      
      <!-- Horizontal Scroll Carousel -->
      <div class="flex overflow-x-auto pb-6 -mx-4 px-4 md:-mx-6 md:px-6 snap-x snap-mandatory custom-scrollbar gap-4 md:gap-6">
        {carouselPosts.map((post) => {
          const img = post.metadata?.data?.image1 
            || post.metadata?.blocks?.find((b: any) => b.type === 'image')?.url
            || post.metadata?.thumbnail_url
            || post.thumbnail_url;
            
          return (
            <a href={`/${post.slug || post.id}`} class="flex flex-col flex-none w-[240px] md:w-[280px] snap-start group pb-2">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden mb-4 relative shadow-sm border border-slate-100 group-hover:shadow-xl group-hover:shadow-indigo-100 transition-all">
                {img ? (
                  <img src={img} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                ) : (
                  <div class="w-full h-full bg-slate-100 flex items-center justify-center">
                    <span class="text-slate-300 font-bold text-4xl">{post.title.substring(0, 1)}</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
              <h3 class="font-bold text-slate-900 text-lg line-clamp-2 leading-snug group-hover:text-indigo-600 transition-colors min-h-[3.2rem]">
                {post.title}
              </h3>
              <p class="mt-2 text-sm text-slate-500 font-medium">
                {new Date(post.publish_at || post.created_at).toLocaleDateString()}
              </p>
            </a>
          )
        })}
      </div>
    </div>
  </div>

  <style is:global>
    /* Custom Scrollbar for the carousel */
    .custom-scrollbar::-webkit-scrollbar {
      height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }
    .custom-scrollbar {
      scrollbar-width: thin;
      scrollbar-color: #cbd5e1 transparent;
    }
  </style>
</section>
