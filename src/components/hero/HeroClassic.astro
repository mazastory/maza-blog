---
export interface Props {
  blogName: string;
  blogDescription: string;
  heroBgUrl?: string | null;
  t: any;
  posts: any[];
}
const { blogName, blogDescription, heroBgUrl, t, posts } = Astro.props;
---

<section class="relative mb-10 md:mb-16 overflow-hidden rounded-3xl md:rounded-[40px] bg-white border border-slate-200 p-8 md:p-14 lg:p-20 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
  {heroBgUrl && (
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <img src={heroBgUrl} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-white/80 backdrop-blur-sm"></div>
    </div>
  )}
  <div class="relative z-10 flex flex-col items-center text-center max-w-4xl mx-auto">
    <div class="mb-6 flex items-center justify-center">
      <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-slate-500">
        {blogName}
      </span>
    </div>
    <h1 class={`${blogDescription.length > 40 ? 'text-3xl md:text-4xl lg:text-5xl leading-[1.3]' : blogDescription.length > 20 ? 'text-4xl md:text-5xl lg:text-6xl leading-[1.2]' : 'text-5xl md:text-6xl lg:text-7xl leading-[1.15]'} font-serif font-black tracking-tight text-slate-900 break-keep`} style="word-break: keep-all; overflow-wrap: break-word;">
      {blogDescription}
    </h1>
    <div class="w-24 h-1 bg-slate-900 mx-auto mt-8 mb-8 rounded-full"></div>
    <p class="max-w-2xl text-lg md:text-xl leading-relaxed text-slate-500 font-medium break-keep">
      {t.welcome}
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/about" class="inline-flex items-center justify-center rounded-full bg-slate-900 px-8 py-3.5 text-sm font-bold tracking-wide text-white transition-colors hover:bg-slate-800">
        {t.about}
      </a>
      <a href="/contact" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-8 py-3.5 text-sm font-bold tracking-wide text-slate-700 transition-colors hover:bg-slate-50">
        {t.contact}
      </a>
    </div>
  </div>

  {posts.length === 0 && (
    <div class="mt-16 grid gap-6 sm:grid-cols-3 max-w-5xl mx-auto border-t border-slate-100 pt-12">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-wider text-slate-400">{t.pubFlow}</p>
        <p class="mt-2 text-lg font-bold text-slate-800">{t.pubFlowDesc}</p>
      </div>
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-wider text-slate-400">{t.layout}</p>
        <p class="mt-2 text-lg font-bold text-slate-800">{t.layoutDesc}</p>
      </div>
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-wider text-slate-400">{t.seo}</p>
        <p class="mt-2 text-lg font-bold text-slate-800">{t.seoDesc}</p>
      </div>
    </div>
  )}
</section>
