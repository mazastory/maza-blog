---
export interface Props {
  blogName: string;
  blogDescription: string;
  heroBgUrl?: string | null;
  t: any;
  posts: any[];
  heroSubtitle: string;
}
const { blogName, blogDescription, heroBgUrl, t, posts, heroSubtitle } = Astro.props;

// Use heroBgUrl first, then the latest post image, then fallback
let bgImg = heroBgUrl || '/hero-bg-picasso.png';
if (!heroBgUrl && posts.length > 0) {
  const metaImg = posts[0].metadata?.data?.image1 
    || posts[0].metadata?.blocks?.find((b: any) => b.type === 'image')?.url
    || posts[0].metadata?.thumbnail_url
    || posts[0].thumbnail_url
    || null;
  if (metaImg) bgImg = metaImg;
}
---

<section class="relative mb-10 md:mb-16 overflow-hidden rounded-3xl md:rounded-[40px] shadow-2xl h-[500px] md:h-[600px] flex items-end p-8 md:p-14 lg:p-20 group">
  <!-- Full Bleed Background Image -->
  <div class="absolute inset-0">
    <img src={bgImg} alt="Hero Background" class="w-full h-full object-cover transition-transform duration-[20s] group-hover:scale-110" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>
  </div>
  
  <div class="relative z-10 w-full max-w-4xl">
    <div class="mb-4">
      <span class="inline-block bg-white text-black px-3 py-1 text-xs font-black uppercase tracking-[0.1em]">
        {blogName}
      </span>
    </div>
    <h1 class={`${blogDescription.length > 40 ? 'text-3xl md:text-4xl lg:text-5xl' : 'text-4xl md:text-5xl lg:text-6xl'} font-black tracking-tight text-white leading-tight break-keep`} style="word-break: keep-all; overflow-wrap: break-word;">
      {blogDescription}
    </h1>
    <p class="mt-6 max-w-2xl text-lg md:text-xl text-slate-300 font-medium break-keep">
      {heroSubtitle}
    </p>
    <div class="mt-8 flex gap-4">
      <a href="/about" class="text-white text-sm font-bold uppercase tracking-wider border-b-2 border-white pb-1 hover:text-slate-300 hover:border-slate-300 transition-colors">
        {t.about} →
      </a>
    </div>
  </div>
</section>
