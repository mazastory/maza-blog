---
export interface Props {
  blogName: string;
  blogDescription: string;
  heroBgUrl?: string | null;
  t: any;
  posts: any[];
  heroSubtitle: string;
}
const { blogName, blogDescription, heroBgUrl, t, posts, heroSubtitle } = Astro.props;

let bgImg = heroBgUrl || '/hero-bg-picasso.png';
if (!heroBgUrl && posts.length > 0) {
  const metaImg = posts[0].metadata?.data?.image1 
    || posts[0].metadata?.blocks?.find((b: any) => b.type === 'image')?.url
    || posts[0].metadata?.thumbnail_url
    || posts[0].thumbnail_url
    || null;
  if (metaImg) bgImg = metaImg;
}
---

<section class="relative mb-10 md:mb-16 overflow-hidden rounded-3xl md:rounded-[40px] bg-slate-900 shadow-2xl flex flex-col md:flex-row">
  <div class="w-full md:w-1/2 p-8 md:p-14 lg:p-20 flex flex-col justify-center relative z-10">
    <div class="mb-8">
      <span class="inline-block border border-slate-700 bg-slate-800/50 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-slate-300 rounded-lg">
        {blogName}
      </span>
    </div>
    <h1 class={`${blogDescription.length > 40 ? 'text-3xl md:text-4xl' : 'text-4xl md:text-5xl lg:text-6xl'} font-black tracking-tight text-white leading-[1.2] break-keep`} style="word-break: keep-all; overflow-wrap: break-word;">
      {blogDescription}
    </h1>
    <p class="mt-6 text-lg text-slate-400 font-medium break-keep">
      {heroSubtitle}
    </p>
    <div class="mt-10 flex gap-4">
      <a href="/about" class="rounded-xl bg-white px-6 py-3 text-sm font-bold text-slate-900 hover:bg-slate-200 transition-colors">
        {t.about}
      </a>
      <a href="/contact" class="rounded-xl border border-slate-700 px-6 py-3 text-sm font-bold text-slate-300 hover:bg-slate-800 transition-colors">
        {t.contact}
      </a>
    </div>
  </div>
  
  <div class="w-full md:w-1/2 min-h-[300px] md:min-h-full relative">
    <div class="absolute inset-0 bg-indigo-500/20 mix-blend-multiply z-10"></div>
    <img src={bgImg} alt="Hero Background" class="absolute inset-0 w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" />
  </div>
</section>
