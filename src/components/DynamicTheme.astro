---
import { getSiteConfig, getRequestDomain } from '../lib/api';
import { generateThemeVars } from '../lib/theme';

const { siteConfig: propSiteConfig } = Astro.props;
const domain = getRequestDomain(Astro.request);
const siteConfig = propSiteConfig || await getSiteConfig(domain);

const theme = generateThemeVars(siteConfig);
---

<link rel="stylesheet" href={theme.fontUrl} />

<style is:inline set:html={`
  :root {
    --hex: ${theme.color};
    --font-family-base: ${theme.fontFamily};
    /* Override Tailwind v4 indigo scale with the brand color using color-mix for shades */
    --color-indigo-50: color-mix(in srgb, var(--hex) 5%, white);
    --color-indigo-100: color-mix(in srgb, var(--hex) 15%, white);
    --color-indigo-200: color-mix(in srgb, var(--hex) 30%, white);
    --color-indigo-300: color-mix(in srgb, var(--hex) 45%, white);
    --color-indigo-400: color-mix(in srgb, var(--hex) 70%, white);
    --color-indigo-500: color-mix(in srgb, var(--hex) 85%, white);
    --color-indigo-600: var(--hex);
    --color-indigo-700: color-mix(in srgb, var(--hex) 85%, black);
    --color-indigo-800: color-mix(in srgb, var(--hex) 70%, black);
    --color-indigo-900: color-mix(in srgb, var(--hex) 55%, black);
    --color-indigo-950: color-mix(in srgb, var(--hex) 40%, black);
  }
  
  html {
    font-family: var(--font-family-base);
  }
`} />

